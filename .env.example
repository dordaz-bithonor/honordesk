# PostgreSQL (Supabase): use the pooler connection string for the app.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Direct connection (migrations). Often port 5432 without pgbouncer.
# For local Postgres without a pooler, you can set the same value as DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# MVP access: 4-digit PIN (set in Vercel for production).
HONORDESK_PIN="0000"
