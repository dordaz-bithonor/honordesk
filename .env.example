# PostgreSQL (Supabase): pooler transaccional (:6543 / host pooler.*) para la app.
# Incluye siempre ?pgbouncer=true (o &pgbouncer=true); si falta, Prisma puede fallar con:
# Postgres 42P05 "prepared statement \"sN\" already exists".
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"

# Direct connection (migrations). Often port 5432 without pgbouncer.
# For local Postgres without a pooler, you can set the same value as DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# MVP access: 4-digit PIN (set in Vercel for production).
HONORDESK_PIN="0000"

# Opcional: email del usuario interno que se crea solo si no hay usuarios (p. ej. sin seed).
# HONORDESK_SYSTEM_USER_EMAIL="ops@tuempresa.com"
